# LLM Configuration (choose one provider)

# --- OpenRouter (default, recommended) ---
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.5-9b  
qwen/qwen3-14b  

# --- OpenAI direct ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Local vLLM (no API key needed) ---
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=your-model-name
# VLLM_API_KEY=dummy

# --- Local Ollama (no API key needed) ---
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1:8b

# Alternative key names (also supported)
# ONLINE_LLM_KEY=your-openrouter-key
# VLLM_API_KEY=your-key
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL_NAME=your-model-name